# Postgres connection string (Vercel Postgres / Neon).
# In Vercel, add the Neon integration and the platform injects POSTGRES_URL automatically.
# For local dev, point this at any Postgres 13+ database.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Anthropic Claude API key — required by the analysis pipeline.
ANTHROPIC_API_KEY=

# Optional: shared secret for /api/admin/* ops endpoints.
# When set, admin routes require `Authorization: Bearer <ADMIN_TOKEN>`.
# When unset, /api/admin/analyze/[id] only triggers stuck rows (status=processing,
# analysis_started_at IS NULL, created_at older than 5 min) — safe bootstrap mode.
ADMIN_TOKEN=

# --- Telegram bridge (IDEAA-27) ---
# Token from @BotFather. Required for the bot to send/receive messages.
TELEGRAM_BOT_TOKEN=
# Random secret registered with setWebhook; Telegram echoes it in the
# X-Telegram-Bot-Api-Secret-Token header so we can reject spoofed webhooks.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated list of allowed Telegram user IDs (numeric). Anything else
# is dropped silently. Initial value: just Jan.
TELEGRAM_ALLOWED_USER_IDS=
# Public URL of this Next.js app. Defaults to https://$VERCEL_URL when unset.
# Used by /api/telegram/admin op=register-webhook.
TELEGRAM_PUBLIC_APP_URL=
# Jan's Paperclip user ID — used to filter "assigned to Jan" issues for push.
JAN_PAPERCLIP_USER_ID=
# Vercel Cron auth shared secret. Vercel sends Bearer <CRON_SECRET> on the
# scheduled hit to /api/telegram/push.
CRON_SECRET=

# --- Paperclip API (used by the Telegram bridge) ---
# Base URL of the Paperclip API.
PAPERCLIP_API_URL=
# Long-lived service-token API key for the bot worker.
PAPERCLIP_BOT_API_KEY=
# Paperclip company id.
PAPERCLIP_COMPANY_ID=
# UI prefix for issue links rendered in Telegram messages (e.g. "IDEAA").
PAPERCLIP_UI_PREFIX=IDEAA
